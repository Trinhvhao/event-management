// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum UserRole {
  student
  organizer
  admin
  teacher
  external
}

enum EventStatus {
  pending
  approved
  upcoming
  ongoing
  completed
  cancelled
}

enum RegistrationStatus {
  registered
  cancelled
  attended
}

enum ApprovalStatus {
  pending    // Chờ duyệt
  approved   // Đã duyệt
  rejected   // Từ chối
}

enum AttendanceStatus {
  checked_in
  checked_out
}

enum NotificationType {
  registration_confirm
  event_reminder
  event_update
  event_cancelled
  feedback_request
  checkin_success
  points_awarded
  ticket_created
}

enum TicketStatus {
  valid
  used
  cancelled
  expired
}

enum PaymentStatus {
  pending
  paid
  failed
  cancelled
  expired
  refunded
}

enum PaymentMethod {
  payos
  vnpay
  bank_transfer
  cash
}

enum ApprovalType {
  auto_approve  // Tự động duyệt
  require_approval  // Cần phê duyệt
  no_registration  // Không cần đăng ký (sự kiện tự do)
}

// Models
model User {
  id                   Int       @id @default(autoincrement())
  email                String    @unique
  password_hash        String
  full_name            String
  student_id           String?   @unique
  role                 UserRole
  department_id        Int?
  is_active            Boolean   @default(true)
  email_verified       Boolean   @default(false)
  avatar_url          String?
  notification_enabled Boolean   @default(true)
  notification_preferences Json?
  last_login           DateTime?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  // Relations
  department             Department?     @relation(fields: [department_id], references: [id], onUpdate: SetNull)
  organized_events       Event[]         @relation("EventOrganizer")
  event_team_memberships EventTeamMember[]
  added_team_members     EventTeamMember[] @relation("AddedByUser")
  registrations          Registration[]
  training_points        TrainingPoint[]
  feedback               Feedback[]
  notifications          Notification[]
  checked_in_attendances Attendance[]    @relation("CheckedBy")
  audit_logs_as_admin    AuditLog[]      @relation("AuditAdmin")
  audit_logs_as_user     AuditLog[]      @relation("AuditUser")
  approved_registrations  Registration[]  @relation("ApprovedBy")
  waitlist_entries       EventWaitlist[]
  payments               Payment[]

  @@index([email])
  @@index([student_id])
  @@index([role])
  @@index([last_login])
  @@index([role, is_active])
  @@index([department_id, role])
  @@index([created_at])
  @@map("users")
}

model Department {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  code        String   @unique
  description String?
  created_at  DateTime @default(now())

  // Relations
  users  User[]
  events Event[]

  @@map("departments")
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  created_at  DateTime @default(now())

  // Relations
  events Event[]

  @@map("categories")
}

model Event {
  id                    Int         @id @default(autoincrement())
  title                 String
  description           String?
  start_time            DateTime
  end_time              DateTime
  location              String
  category_id           Int
  department_id          Int
  organizer_id          Int?
  capacity              Int
  training_points       Int         @default(0)
  event_cost            Decimal     @default(0)   @db.Decimal(10, 0)
  status                EventStatus @default(upcoming)
  image_url             String?
  is_featured           Boolean     @default(false)
  registration_deadline DateTime?
  deleted_at            DateTime?
  created_at            DateTime    @default(now())
  updated_at            DateTime    @updatedAt

  // Approval settings
  approval_type         ApprovalType @default(auto_approve)  // Loại hình thức đăng ký
  require_reason        Boolean      @default(false)         // Có yêu cầu lý do đăng ký

  // Agreement/Terms settings
  require_agreement     Boolean      @default(true)         // Yêu cầu đồng ý nội quy
  agreement_text        String?                           // Nội quy riêng cho sự kiện này (null = dùng mặc định)

  // Relations
  category                Category        @relation(fields: [category_id], references: [id], onDelete: Cascade)
  department              Department      @relation(fields: [department_id], references: [id], onDelete: Cascade)
  organizer               User?           @relation("EventOrganizer", fields: [organizer_id], references: [id], onDelete: SetNull, onUpdate: SetNull)
  team_members            EventTeamMember[]
  registrations           Registration[]
  awarded_training_points TrainingPoint[]
  feedback                Feedback[]
  notifications           Notification[]
  waitlist                EventWaitlist[]
  payments                Payment[]

  @@index([start_time])
  @@index([status])
  @@index([category_id])
  @@index([department_id])
  @@index([organizer_id])
  @@index([organizer_id, status])
  @@map("events")
}

model Registration {
  id            Int                @id @default(autoincrement())
  user_id       Int
  event_id      Int
  registered_at DateTime           @default(now())
  status        RegistrationStatus @default(registered)
  qr_code       String

  // Approval fields
  approval_status  ApprovalStatus @default(approved)  // pending, approved, rejected
  approval_note    String?                          // Ghi chú từ người duyệt
  approved_by      Int?
  approved_at      DateTime?

  // Lý do đăng ký
  reason          String?

  // Cam kết/Đồng ý nội quy
  agreed_at       DateTime?                          // Thời điểm đồng ý cam kết

  // Relations
  user       User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  event      Event       @relation(fields: [event_id], references: [id], onDelete: Cascade)
  approver   User?       @relation("ApprovedBy", fields: [approved_by], references: [id])
  attendance Attendance?
  payment    Payment?
  ticket     Ticket?

  @@unique([user_id, event_id])
  @@index([user_id])
  @@index([event_id])
  @@index([event_id, status])
  @@index([approval_status])
  @@map("registrations")
}

model Payment {
  id              Int           @id @default(autoincrement())
  registration_id Int           @unique
  user_id         Int
  event_id        Int
  amount          Decimal       @db.Decimal(10, 0)
  currency        String        @default("VND")
  status          PaymentStatus @default(pending)
  method          PaymentMethod @default(payos)
  payos_order_id String?       @unique
  payos_payment_id String?
  transaction_id  String?      @unique
  metadata        Json?
  paid_at         DateTime?
  expires_at      DateTime?
  failure_reason  String?
  refund_reason   String?
  refunded_at     DateTime?
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  // Relations
  registration Registration @relation(fields: [registration_id], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  event        Event        @relation(fields: [event_id], references: [id])

  @@index([user_id])
  @@index([event_id])
  @@index([status])
  @@index([payos_order_id])
  @@index([transaction_id])
  @@map("payments")
}

model Attendance {
  id              Int              @id @default(autoincrement())
  registration_id Int              @unique
  checked_in_at   DateTime         @default(now())
  checked_out_at  DateTime?
  status         AttendanceStatus  @default(checked_in)
  checked_by     Int

  // Relations
  registration Registration @relation(fields: [registration_id], references: [id], onDelete: Cascade)
  checker      User         @relation("CheckedBy", fields: [checked_by], references: [id])

  @@index([registration_id])
  @@index([status])
  @@index([checked_in_at])
  @@map("attendance")
}

model TrainingPoint {
  id        Int      @id @default(autoincrement())
  user_id   Int
  event_id  Int
  points    Int
  semester  String
  earned_at DateTime @default(now())

  // Relations
  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  event Event @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@unique([user_id, event_id])
  @@index([user_id])
  @@index([semester])
  @@map("training_points")
}

model Feedback {
  id           Int      @id @default(autoincrement())
  event_id     Int
  user_id      Int
  rating       Int
  comment      String?
  suggestions  String?
  is_anonymous Boolean  @default(false)
  created_at   DateTime @default(now())

  // Relations
  event Event @relation(fields: [event_id], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, event_id])
  @@index([event_id])
  @@map("feedback")
}

model Notification {
  id       Int              @id @default(autoincrement())
  user_id  Int
  event_id Int?
  type     NotificationType
  title    String
  message  String
  is_read  Boolean          @default(false)
  sent_at  DateTime         @default(now())

  // Relations
  user  User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [event_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([is_read])
  @@map("notifications")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  action_type String
  admin_id    Int
  user_id     Int?
  entity_type String?
  entity_id   Int?
  old_value   Json?
  new_value   Json?
  metadata    Json?
  ip_address  String?
  user_agent  String?
  created_at  DateTime @default(now())

  // Relations
  admin User  @relation("AuditAdmin", fields: [admin_id], references: [id], onDelete: Cascade)
  user  User? @relation("AuditUser", fields: [user_id], references: [id], onDelete: SetNull)

  @@index([admin_id])
  @@index([user_id])
  @@index([action_type])
  @@index([created_at])
  @@index([entity_type, entity_id])
  @@map("audit_logs")
}

enum WaitlistStatus {
  waiting
  promoted
  cancelled
}

enum EventTeamRole {
  main_organizer
  helper
}

model EventTeamMember {
  id         Int          @id @default(autoincrement())
  event_id   Int
  user_id    Int
  role       EventTeamRole
  added_by   Int
  created_at DateTime     @default(now())

  event       Event @relation(fields: [event_id], references: [id], onDelete: Cascade)
  user        User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  added_by_user User @relation("AddedByUser", fields: [added_by], references: [id])

  @@unique([event_id, user_id])
  @@index([event_id])
  @@index([user_id])
  @@map("event_team_members")
}

model EventWaitlist {
  id        Int            @id @default(autoincrement())
  event_id  Int
  user_id   Int
  position  Int
  status    WaitlistStatus @default(waiting)
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt

  // Relations
  event Event @relation(fields: [event_id], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([event_id, user_id])
  @@index([event_id])
  @@index([user_id])
  @@index([event_id, status])
  @@index([position])
  @@map("event_waitlist")
}

model Ticket {
  id              Int         @id @default(autoincrement())
  ticket_code     String      @unique
  registration_id Int         @unique
  qr_data         String
  qr_image        String?
  pdf_url         String?
  status          TicketStatus @default(valid)
  sent_at         DateTime?
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt

  // Relations
  registration Registration @relation(fields: [registration_id], references: [id], onDelete: Cascade)

  @@index([ticket_code])
  @@index([status])
  @@map("tickets")
}
