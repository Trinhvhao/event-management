# Database
DATABASE_URL="postgresql://user:password@localhost:5432/event_management"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="24h"

# Email Configuration
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
EMAIL_FROM="Event Management <noreply@university.edu.vn>"

# SePay Payment Gateway (No Authentication mode - no API key needed)
SEPAY_ACCOUNT_NUMBER="your-sepay-account-number"
SEPAY_BANK_NAME="Vietcombank"
# Webhook URL - must be publicly accessible
SEPAY_WEBHOOK_URL="https://api.hayyie.click/api/payments/webhook"

# Application
PORT=7776
NODE_ENV="development"
FRONTEND_URL="https://hayyie.click"
CLIENT_URL="https://hayyie.click"

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN="http://localhost:7777,https://hayyie.click,https://api.hayyie.click"

# Optional: Disable email sending in dev (set to "true" to disable)
# DISABLE_EMAIL_SENDING="true"
